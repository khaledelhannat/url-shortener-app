# .env.example — Copy to .env and fill in values before running locally.
# This file IS committed to the repository.
# The .env file is NEVER committed (add to .gitignore).

# ── PostgreSQL ──────────────────────────────────────────────────────────────
# Required — application fails to start if unset.
POSTGRES_PASSWORD=changeme

# Optional — defaults shown.
POSTGRES_USER=appuser
POSTGRES_DB=urlshortener

# Constructed by docker-compose from the above. Override here to point at
# an external DB (e.g., RDS) without changing docker-compose.yml.
# DATABASE_URL=postgresql+asyncpg://appuser:changeme@postgres:5432/urlshortener

# ── Redis ───────────────────────────────────────────────────────────────────
# Constructed by docker-compose. Override to point at external Redis.
# REDIS_URL=redis://redis:6379/0

# Cache TTL in seconds for redirect entries. Default: 3600 (1 hour).
# CACHE_TTL_SECONDS=3600

# ── Application ─────────────────────────────────────────────────────────────
# Base URL used when constructing short_url in POST /shorten responses.
# Set to the public hostname in staging/production.
BASE_URL=http://localhost:8000

# Log level: debug | info | warning | error
LOG_LEVEL=info

# Enable /docs (Swagger UI). Set to false in production.
ENABLE_DOCS=true

# Short code length in characters. Default: 6 (62^6 ≈ 56 billion combinations).
# SHORT_CODE_LENGTH=6

# Host port for the API container (change if 8000 conflicts locally).
API_PORT=8000
